# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://megaparser:megaparser@localhost:5432/megaparser

# Telegram control bot (aiogram)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here
ALLOWED_ADMIN_IDS=123456789,987654321

# Fernet symmetric key for encrypting session_string/twoFA in DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Paths
DATA_DIR=./sessions
CONFIG_PATH=./config.yaml
LOG_DIR=./logs

# Runtime flags
LOG_LEVEL=INFO
DRY_RUN=false
